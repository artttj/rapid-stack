#!/usr/bin/env bash
# Adapted from superpowers (MIT, github.com/obra/superpowers) session-start hook.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

content=$(cat "${PLUGIN_ROOT}/skills/using-op/SKILL.md" 2>&1 || echo "Error reading using-op skill")
content="${content//__OP_ROOT__/${PLUGIN_ROOT}}"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

escaped=$(escape_for_json "$content")
ctx="<op-rules>\nThe op operator rules for this session:\n\n${escaped}\n</op-rules>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$ctx" | cat

exit 0
